import logging
import sys

from di_live_lib import (
    TargetMounts,
    dilive_system,
    preset_debconf,
    setup_logging,
    target_mounted,
)

logger = logging.getLogger(__name__)


def main() -> None:
    logger.debug(f"{__file__}.main()")
    if not target_mounted("/target"):
        logger.debug(" ! '/target' not mounted")
        sys.exit(10)  # return to menu

    # mount bind dev, proc & sys on target otherwise grub-installer will fail
    _targetmounts = TargetMounts("/target")

    preseeds: list[tuple[str, str | bool]] = [
        ("grub-installer/only_debian", True),
        ("grub-installer/with_other_os", True),
        ("grub-installer/bootdev", "default"),
        ("grub-installer/bootdev", "/dev/sda"),
    ]

    preset_debconf(preseeds=preseeds)

    dilive_system(["/usr/share/grub-installer/grub-installer", "/target"])


if __name__ == "__main__":
    setup_logging()
    main()
